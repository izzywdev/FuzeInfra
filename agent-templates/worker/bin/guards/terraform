#!/usr/bin/env bash
# Guard shim: plan-only. plan/validate/fmt/show pass through; apply/destroy/
# import/state do not (mutations go through the terraform-plan-apply CD).
set -euo pipefail
REAL=/usr/local/bin/terraform
for a in "$@"; do
  case "$a" in
    apply|destroy|import|state)
      echo "guard: 'terraform $a' is blocked on this worker (plan-only; apply via CD)" >&2
      exit 97 ;;
  esac
done
exec "$REAL" "$@"
