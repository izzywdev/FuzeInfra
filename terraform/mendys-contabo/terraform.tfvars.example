# Copy to terraform.tfvars and fill in real values. NEVER commit terraform.tfvars.
# In CI these are supplied as TF_VAR_* env from FuzeInfra GitHub Actions secrets.

# --- Contabo ---
contabo_client_id     = ""
contabo_client_secret = ""
contabo_api_user      = "your-email@example.com"
contabo_api_password  = ""

# --- VPS ---
image_id              = ""   # Ubuntu 24.04 LTS image UUID
product_id            = ""   # e.g. VPS S (4 vCPU / 8 GB) product UUID
instance_display_name = "mendys-prod"
ssh_public_key        = "ssh-ed25519 AAAA..."
ssh_private_key_path  = "~/.ssh/id_ed25519"

# --- TLS (REQUIRED — no default; validated non-empty) ---
letsencrypt_email = "izzy.weinberg@gmail.com"

# --- Cloudflare (DNS-only, proxied=false) ---
cloudflare_api_token = ""
cloudflare_zone_id   = ""   # Zone ID for mendysrobotics.com (CLOUDFLARE_ZONE_ID_MENDYS)
domain               = "mendysrobotics.com"

# subdomains default: live, api.live, marketplace, wp, argocd
# apex/www are NOT managed here — owned by MendysRobotics landing/infra/terraform.
