# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.
#
# A single `terraform apply` in this directory provisions:
#   1. Contabo VPS + k3s + ArgoCD
#   2. Cloudflare Named Tunnel + DNS records + Zero Trust Access  (if api_token set)
#   3. GitHub KUBE_CONFIG secret for CI/CD  (if github_token set)
#   4. Tunnel token injected into the cluster secret automatically

# -----------------------------------------------------------------------
# Contabo API credentials
# 1. Log in to https://new.contabo.com
# 2. Go to Account → API Credentials → Create credentials
# -----------------------------------------------------------------------
contabo_client_id     = ""   # shown after creating API credentials
contabo_client_secret = ""   # shown after creating API credentials
contabo_api_user      = "your-email@example.com"
contabo_api_password  = ""   # your Contabo account password

# -----------------------------------------------------------------------
# VPS configuration
# Find image and product IDs:
#   Images: https://new.contabo.com/cloud/compute/images
#           or GET https://api.contabo.com/v1/compute/images
#   Products: visible in the pricing page or via Contabo API
# -----------------------------------------------------------------------
image_id              = ""   # e.g. Ubuntu 24.04 LTS image UUID
product_id            = ""   # e.g. VPS S (4 vCPU / 8 GB) product UUID
instance_display_name = "fuzeinfra-prod"

# -----------------------------------------------------------------------
# SSH access
# ssh_public_key: contents of ~/.ssh/id_ed25519.pub (multi-line is fine)
# -----------------------------------------------------------------------
ssh_public_key       = "ssh-ed25519 AAAA..."
ssh_private_key_path = "~/.ssh/id_ed25519"
server_user          = "root"

# -----------------------------------------------------------------------
# Domain (optional — leave blank to skip Traefik Ingress hostnames)
# When cloudflare_api_token is set, prod.fuzefront.com is auto-created.
# This var is for additional custom domain Ingress rules (rarely needed).
# -----------------------------------------------------------------------
domain = ""

# -----------------------------------------------------------------------
# GitHub
# Token needs: repo (full), admin:repo_hook, secrets (write)
# Create at: https://github.com/settings/tokens
# -----------------------------------------------------------------------
github_token = ""
github_owner = "izzywdev"
github_repo  = "FuzeInfra"

# -----------------------------------------------------------------------
# Cloudflare Zero Trust (leave cloudflare_api_token empty to skip all of this)
#
# When set, terraform apply will automatically:
#   - Create a Named Tunnel ("fuzeinfra-prod") in your Cloudflare account
#   - Add DNS records: prod.fuzefront.com + *.prod.fuzefront.com
#   - Create Access app protecting *.prod.fuzefront.com with email OTP
#   - Inject the tunnel token into the k3s cluster — no manual step
#
# Required token permissions:
#   Zone > DNS > Edit
#   Account > Cloudflare Tunnel > Edit
#   Account > Access: Apps and Policies > Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
# -----------------------------------------------------------------------
cloudflare_api_token  = ""   # leave empty to skip
cloudflare_account_id = ""   # from https://dash.cloudflare.com → account settings URL
cloudflare_zone_id    = ""   # from zone overview page in Cloudflare dashboard

# Defaults below are correct for fuzefront.com — adjust only if different:
# tunnel_name           = "fuzeinfra-prod"
# prod_subdomain        = "prod"        # → prod.fuzefront.com
# zone_name             = "fuzefront.com"
# allowed_admin_emails  = ["izzy.weinberg@gmail.com"]
# access_session_duration = "24h"

# -----------------------------------------------------------------------
# To import the existing Contabo server (do this BEFORE terraform apply):
#   terraform import contabo_compute_instance.prod <your-instance-uuid>
#
# Find your instance UUID:
#   curl -s -H "Authorization: Bearer <token>" \
#     https://api.contabo.com/v1/compute/instances | jq '.data[].instanceId'
# -----------------------------------------------------------------------
